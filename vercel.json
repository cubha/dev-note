{
  "framework": null,
  "installCommand": "npm install @upstash/redis",
  "buildCommand": "",
  "outputDirectory": "",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "feature/*": false
    }
  },
  "rewrites": [
    { "source": "/v1/messages", "destination": "/api/v1/messages" },
    { "source": "/v1/error-report", "destination": "/api/v1/error-report" },
    { "source": "/v1/metrics", "destination": "/api/v1/metrics" },
    { "source": "/v1/visits", "destination": "/api/v1/visits" }
  ]
}
